<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HomepageController"
            style="-fx-background-color: #FAF8F3;">

    <!-- Top Section -->
    <top>
        <VBox spacing="20.0" alignment="CENTER" style="-fx-background-color: #321F08;">
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0"/>
            </padding>

            <Label text="Hotel Reservation System" style="-fx-text-fill: #FAF8F3;">
                <font>
                    <Font name="Times New Roman Bold" size="42.0"/>
                </font>
            </Label>

            <Label text="Your Comfort, Our Priority" style="-fx-text-fill: #FAF8F3;">
                <font>
                    <Font name="Times New Roman Italic" size="20.0"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- Center Section -->
    <center>
        <VBox spacing="35.0" alignment="CENTER" style="-fx-background-color: #FAF8F3;">
            <padding>
                <Insets bottom="50.0" left="80.0" right="80.0" top="50.0"/>
            </padding>

            <!-- Welcome Message -->
            <VBox spacing="15.0" alignment="CENTER" maxWidth="700.0">
                <Label text="Welcome to Our Hotel" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="32.0"/>
                    </font>
                </Label>

                <Label text="Experience luxury and comfort with our state-of-the-art reservation system. Whether you're planning a business trip or a leisure getaway, we make booking your perfect room effortless."
                       wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman" size="16.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- Features Section -->
            <GridPane hgap="40.0" vgap="30.0" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                    <ColumnConstraints/>
                </columnConstraints>

                <!-- Feature 1 -->
                <VBox spacing="12.0" alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #321F08; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"
                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0"/>
                    </padding>
                    <Label text="Easy Booking" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman Bold" size="18.0"/>
                        </font>
                    </Label>
                    <Label text="Search and book your ideal room in just a few clicks" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman" size="14.0"/>
                        </font>
                    </Label>
                </VBox>

                <!-- Feature 2 -->
                <VBox spacing="12.0" alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #321F08; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"
                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0"/>
                    </padding>
                    <Label text="Manage Reservations" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman Bold" size="18.0"/>
                        </font>
                    </Label>
                    <Label text="View and manage all your reservations from one place" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman" size="14.0"/>
                        </font>
                    </Label>
                </VBox>

                <!-- Feature 3 -->
                <VBox spacing="12.0" alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #321F08; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"
                      GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0"/>
                    </padding>
                    <Label text="Premium Services" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman Bold" size="18.0"/>
                        </font>
                    </Label>
                    <Label text="Access exclusive hotel services and amenities during your stay" wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #321F08;">
                        <font>
                            <Font name="Times New Roman" size="14.0"/>
                        </font>
                    </Label>
                </VBox>
            </GridPane>

            <!-- Call to Action -->
            <VBox spacing="20.0" alignment="CENTER">
                <VBox.margin>
                    <Insets top="20.0"/>
                </VBox.margin>

                <Label text="Ready to book your stay?" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="22.0"/>
                    </font>
                </Label>

                <Button fx:id="loginButton" text="Go to Login" onAction="#handleLogin" prefWidth="200.0"
                        style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 5; -fx-background-radius: 5;">
                    <font>
                        <Font name="Times New Roman Bold" size="16.0"/>
                    </font>
                    <padding>
                        <Insets bottom="15.0" left="30.0" right="30.0" top="15.0"/>
                    </padding>
                </Button>
            </VBox>
        </VBox>
    </center>

    <!-- Bottom Section -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #321F08;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
            </padding>
            <Label text="© 2025 Hotel Reservation System. All rights reserved." style="-fx-text-fill: #FAF8F3;">
                <font>
                    <Font name="Times New Roman" size="13.0"/>
                </font>
            </Label>
        </HBox>
    </bottom>
</BorderPane>
