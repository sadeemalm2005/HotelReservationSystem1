<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MyReservationsController"
            style="-fx-background-color: #FAF8F3;">

    <!-- Top Section -->
    <top>
        <VBox spacing="15.0" style="-fx-background-color: #FAF8F3; -fx-border-color: #321F08; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="25.0"/>
            </padding>

            <Label text="My Reservations" style="-fx-text-fill: #321F08;">
                <font>
                    <Font name="Times New Roman Bold" size="26.0"/>
                </font>
            </Label>

            <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack" prefWidth="160.0"
                    style="-fx-background-color: white; -fx-text-fill: #321F08; -fx-cursor: hand; -fx-border-color: #321F08; -fx-border-width: 1.5; -fx-border-radius: 3; -fx-background-radius: 3;">
                <font>
                    <Font name="Times New Roman" size="14.0"/>
                </font>
                <padding>
                    <Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/>
                </padding>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Button>
        </VBox>
    </top>

    <!-- Center Section -->
    <center>
        <HBox spacing="20.0" style="-fx-background-color: #FAF8F3;">
            <padding>
                <Insets bottom="25.0" left="30.0" right="30.0" top="25.0"/>
            </padding>

            <!-- Left: Table -->
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <Label text="All Reservations" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="18.0"/>
                    </font>
                </Label>

                <TableView fx:id="reservationsTable" prefHeight="350.0" style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="reservationIdColumn" text="ID" prefWidth="60.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="roomNumberColumn" text="Room" prefWidth="80.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="checkInColumn" text="Check-In" prefWidth="110.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="checkOutColumn" text="Check-Out" prefWidth="110.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="totalPriceColumn" text="Total" prefWidth="90.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                    </columns>
                </TableView>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                    <Button fx:id="cancelButton" text="Cancel Reservation" onAction="#handleCancel" prefWidth="160.0"
                            style="-fx-background-color: #C62828; -fx-text-fill: white; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>
                </HBox>
            </VBox>

            <!-- Right: Details -->
            <VBox spacing="15.0" prefWidth="280.0" style="-fx-background-color: white; -fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                </padding>

                <Label text="Reservation Details" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="16.0"/>
                    </font>
                </Label>

                <Label fx:id="detailsLabel" wrapText="true" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman" size="13.0"/>
                    </font>
                </Label>

                <Separator style="-fx-background-color: #D3D3D3;"/>

                <Label text="Services" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="14.0"/>
                    </font>
                </Label>

                <ListView fx:id="servicesListView" prefHeight="150.0" style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-font-family: 'Times New Roman'; -fx-font-size: 12;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
