<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.RoomTypeManagementController"
            style="-fx-background-color: #FAF8F3;">

    <!-- Top Section -->
    <top>
        <VBox spacing="15.0" style="-fx-background-color: #FAF8F3; -fx-border-color: #321F08; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="25.0"/>
            </padding>

            <Label text="Room Type Management" style="-fx-text-fill: #321F08;">
                <font>
                    <Font name="Times New Roman Bold" size="26.0"/>
                </font>
            </Label>

            <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack" prefWidth="160.0"
                    style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                <font>
                    <Font name="Times New Roman Bold" size="14.0"/>
                </font>
                <padding>
                    <Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/>
                </padding>
                <VBox.margin>
                    <Insets top="5.0"/>
                </VBox.margin>
            </Button>
        </VBox>
    </top>

    <!-- Center Section -->
    <center>
        <HBox spacing="25.0" style="-fx-background-color: #FAF8F3;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
            </padding>

            <!-- Left: Room Types Table -->
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <Label text="Room Types" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="18.0"/>
                    </font>
                </Label>

                <TableView fx:id="roomTypesTable" prefHeight="450.0" style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="typeIdColumn" text="ID" prefWidth="60.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="typeNameColumn" text="Type Name" prefWidth="150.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="capacityColumn" text="Capacity" prefWidth="100.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="basePriceColumn" text="Base Price" prefWidth="120.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                    </columns>
                </TableView>

                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                    <Button fx:id="deleteButton" text="Delete Type" onAction="#handleDelete" prefWidth="130.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>
                </HBox>
            </VBox>

            <!-- Right: Room Type Form -->
            <VBox spacing="18.0" prefWidth="350.0" style="-fx-background-color: white; -fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                <padding>
                    <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                </padding>

                <Label text="Room Type Details" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="18.0"/>
                    </font>
                </Label>

                <VBox spacing="6.0">
                    <Label text="Type Name:" style="-fx-text-fill: #321F08;">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="typeNameField"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/></padding>
                    </TextField>
                </VBox>

                <VBox spacing="6.0">
                    <Label text="Capacity:" style="-fx-text-fill: #321F08;">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="capacityField"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/></padding>
                    </TextField>
                </VBox>

                <VBox spacing="6.0">
                    <Label text="Base Price:" style="-fx-text-fill: #321F08;">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="basePriceField"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/></padding>
                    </TextField>
                </VBox>

                <VBox spacing="6.0">
                    <Label text="Description:" style="-fx-text-fill: #321F08;">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextArea fx:id="descriptionArea" wrapText="true" prefHeight="120.0"
                             style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-control-inner-background: white;"/>
                </VBox>

                <HBox spacing="12.0" alignment="CENTER">
                    <VBox.margin>
                        <Insets top="15.0"/>
                    </VBox.margin>
                    <Button fx:id="addButton" text="Add Type" onAction="#handleAdd" prefWidth="130.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>

                    <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" prefWidth="130.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>
                </HBox>

                <Label fx:id="messageLabel" text="" style="-fx-text-fill: #321F08;" wrapText="true">
                    <font><Font name="Times New Roman" size="13.0"/></font>
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                </Label>
            </VBox>
        </HBox>
    </center>
</BorderPane>
