<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserManagementController"
            style="-fx-background-color: #FAF8F3;">

    <!-- Top Section -->
    <top>
        <VBox spacing="15.0" style="-fx-background-color: #FAF8F3; -fx-border-color: #321F08; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="25.0"/>
            </padding>

            <Label text="User Management" style="-fx-text-fill: #321F08;">
                <font>
                    <Font name="Times New Roman Bold" size="26.0"/>
                </font>
            </Label>

            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <VBox.margin>
                    <Insets top="10.0"/>
                </VBox.margin>

                <Label text="Search:" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman" size="14.0"/>
                    </font>
                </Label>

                <TextField fx:id="searchField" promptText="Search by username or name" prefWidth="250.0"
                          style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 14; -fx-border-radius: 3; -fx-background-radius: 3;">
                    <padding>
                        <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
                    </padding>
                </TextField>

                <Button fx:id="searchButton" text="Search" onAction="#handleSearch" prefWidth="100.0"
                        style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                    <font>
                        <Font name="Times New Roman Bold" size="14.0"/>
                    </font>
                    <padding>
                        <Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/>
                    </padding>
                </Button>

                <Button fx:id="backButton" text="Back" onAction="#handleBack" prefWidth="80.0"
                        style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                    <font>
                        <Font name="Times New Roman Bold" size="14.0"/>
                    </font>
                    <padding>
                        <Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/>
                    </padding>
                </Button>
            </HBox>
        </VBox>
    </top>

    <!-- Center Section -->
    <center>
        <HBox spacing="25.0" style="-fx-background-color: #FAF8F3;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
            </padding>

            <!-- Left: User Table -->
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <Label text="All Users" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="18.0"/>
                    </font>
                </Label>

                <TableView fx:id="usersTable" prefHeight="450.0" style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="userIdColumn" text="ID" prefWidth="60.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="usernameColumn" text="Username" prefWidth="140.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="150.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="210.0" style="-fx-font-family: 'Times New Roman'; -fx-font-size: 13;"/>
                    </columns>
                </TableView>

                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                    <Button fx:id="deleteButton" text="Delete User" onAction="#handleDelete" prefWidth="120.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>
                </HBox>
            </VBox>

            <!-- Right: User Form -->
            <VBox spacing="15.0" prefWidth="350.0" style="-fx-background-color: white; -fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                <padding>
                    <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                </padding>

                <Label text="User Details" style="-fx-text-fill: #321F08;">
                    <font>
                        <Font name="Times New Roman Bold" size="18.0"/>
                    </font>
                </Label>

                <GridPane hgap="12.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="90.0"/>
                        <ColumnConstraints minWidth="180.0"/>
                    </columnConstraints>

                    <Label text="Username:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </TextField>

                    <Label text="Password:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                  style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </PasswordField>

                    <Label text="First Name:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </TextField>

                    <Label text="Last Name:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </TextField>

                    <Label text="Email:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="4"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </TextField>

                    <Label text="Phone:" style="-fx-text-fill: #321F08;" GridPane.columnIndex="0" GridPane.rowIndex="5">
                        <font><Font name="Times New Roman" size="14.0"/></font>
                    </Label>
                    <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="5"
                              style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: white; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <padding><Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/></padding>
                    </TextField>
                </GridPane>

                <HBox spacing="12.0" alignment="CENTER">
                    <VBox.margin>
                        <Insets top="20.0"/>
                    </VBox.margin>
                    <Button fx:id="addButton" text="Add User" onAction="#handleAdd" prefWidth="120.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>

                    <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" prefWidth="120.0"
                            style="-fx-background-color: #321F08; -fx-text-fill: #FAF8F3; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;">
                        <font>
                            <Font name="Times New Roman Bold" size="14.0"/>
                        </font>
                        <padding>
                            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                        </padding>
                    </Button>
                </HBox>

                <TextArea fx:id="infoArea" wrapText="true" editable="false" prefHeight="100.0"
                         style="-fx-border-color: #D3D3D3; -fx-border-width: 1; -fx-background-color: #FFFEF8; -fx-font-family: 'Times New Roman'; -fx-font-size: 13; -fx-control-inner-background: #FFFEF8;">
                    <VBox.margin>
                        <Insets top="15.0"/>
                    </VBox.margin>
                </TextArea>
            </VBox>
        </HBox>
    </center>
</BorderPane>
